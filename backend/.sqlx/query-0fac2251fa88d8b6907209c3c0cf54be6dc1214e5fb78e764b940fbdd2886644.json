  "query": "\n            SELECT id, recipe_id, recipe_name, cooked_at\n            FROM cook_history\n            WHERE user_id = $1\n              AND cooked_at > $2\n              AND recipe_name ILIKE $3\n            ORDER BY cooked_at DESC\n            ",
